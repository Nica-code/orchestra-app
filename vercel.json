{
  "$schema": "https://openapi.vercel.sh/vercel.json",
  "framework": "nextjs",
  "buildCommand": "next build",
  "devCommand": "next dev",
  "installCommand": "npm install",
  "functions": {
    "app/api/**/*.ts": {
      "runtime": "nodejs20.x"
    }
  },
  "crons": [
    {
      "path": "/api/cron/check-deadlines",
      "schedule": "0 * * * *"
    },
    {
      "path": "/api/cron/reset-billing",
      "schedule": "0 0 1 * *"
    }
  ]
}
